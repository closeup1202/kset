{
  "name": "@closeup1202/kset",
  "version": "1.0.0",
  "description": "Apache Kafka setup CLI — interactive installer for local and Docker environments",
  "main": "dist/index.js",
  "bin": {
    "kset": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && cp -r src/templates dist/templates",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepare": "npm run build"
  },
  "keywords": ["kafka", "apache-kafka", "cli", "setup", "installer", "docker", "kraft"],
  "author": "closeup1202",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0"
  }
}